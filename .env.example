# ── ChatSQL Environment Variables ──────────────────────
# Copy this file to .env and fill in your values

# GROQ API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use
# Options: llama3-70b-8192 | llama3-8b-8192 | mixtral-8x7b-32768 | gemma-7b-it
GROQ_MODEL=llama3-70b-8192

# Database URL (SQLAlchemy format)
# PostgreSQL:  postgresql://user:password@host:5432/dbname
# MySQL:       mysql+pymysql://user:password@host:3306/dbname
# SQLite:      sqlite:///./mydb.sqlite
# MSSQL:       mssql+pyodbc://user:password@host/dbname?driver=ODBC+Driver+17+for+SQL+Server
DATABASE_URL=postgresql://user:password@localhost:5432/your_database

# Flask secret key (change this!)
SECRET_KEY=change-me-to-something-random-2024
